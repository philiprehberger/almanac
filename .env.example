APP_NAME="Almanac"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# PostgreSQL 16 + pgvector >= 0.8 required (iterative_scan)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=almanac
DB_USERNAME=almanac
DB_PASSWORD=almanac_dev_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@almanac.philiprehberger.com"
MAIL_FROM_NAME="Almanac"

# Sentry — leave empty in dev
SENTRY_LARAVEL_DSN=

# LLM providers — leave empty for fixture/mock mode (default)
ALMANAC_DEFAULT_CHAT_PROVIDER=mock
ALMANAC_DEFAULT_EMBED_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# FastAPI embed worker
ALMANAC_EMBED_WORKER_URL=http://127.0.0.1:8001
ALMANAC_EMBED_WORKER_SHARED_SECRET=local-dev-secret

# Connector mock-mode toggle — true in dev/portfolio, false in self-hosted real-OAuth deploys
ALMANAC_CONNECTORS_MOCK_MODE=true

# Public demo fixture workspace slug + cost ceiling
ALMANAC_DEMO_WORKSPACE_SLUG=demo
ALMANAC_DEMO_MONTHLY_BUDGET_USD=25
ALMANAC_DEMO_RATE_LIMIT_PER_HOUR=30
